            self.__next_f.push([1, "1e:[\"$L27\",[\"$\",\"$L28\",null,{\"isHunMatch\":false,\"matchPreviewFullComm\":{\"matchId\":149618,\"commentary\":[{\"inningsId\":0,\"commentaryList\":[{\"commText\":\"Finally everything's sorted and we are ready for the first ball of the match. Here we go!\",\"timestamp\":1774706651187,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"A bit of a false start as the umpires already took their positions. But the producers had to call them back because they have to film them walking in with that IPL theme music.\",\"timestamp\":1774706576899,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"Right then, we are done with the national anthem and it's now time for live action. The SRH openers are out in the middle as Duffy gets ready to bowl the first over of the match.\",\"timestamp\":1774706473025,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"B0$In IPL 2025 at M. Chinnaswamy Stadium, all five toss-winning captains chose to bowl first. The average first-innings score is 169, and chasing teams have won 3 of the 5 matches.\",\"timestamp\":1774706256183,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Stat: \"]}}},{\"commText\":\"The players, spectators and all those present in the stadium observe a moment of silence in remembrance of the 11 individuals who lost their lives last season. And now, we proceed to the national anthem.\",\"timestamp\":1774706256173,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"B0$ \\\\n200 - Ravindra Jadeja  \\\\n153 - Manish Pandey  \\\\n148 - Axar Patel  \\\\n137 - Kieron Pollard  \\\\n126 - Suryakumar Yadav  \\\\n119 - Ishan Kishan*\",\"timestamp\":1774705149200,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Most matches before captaining in IPL \"]}}},{\"commText\":\"B0$\",\"timestamp\":1774705149190,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Here are the Impact substitutes for both the teams:\"]}}},{\"commText\":\"B0$ Shivang Kumar, Liam Livingstone, David Payne, Smaran Ravichandran, Sakib Hussain\",\"timestamp\":1774705149180,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Sunrisers Hyderabad Impact subs:\"]}}},{\"commText\":\"B0$ Devdutt Padikkal, Jacob Bethell, Rasikh Salam Dar, Kanishk Chouhan, Venkatesh Iyer\",\"timestamp\":1774705042306,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Royal Challengers Bengaluru Impact subs:\"]}}},{\"commText\":\"B0$\",\"timestamp\":1774704998551,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Teams:\"]}}},{\"commText\":\"B0$ (Playing XI): Virat Kohli, Philip Salt, Rajat Patidar(c), Jitesh Sharma(w), Tim David, Romario Shepherd, Krunal Pandya, Bhuvneshwar Kumar, Abhinandan Singh, Jacob Duffy, Suyash Sharma\",\"timestamp\":1774704998541,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Royal Challengers Bengaluru\"]}}},{\"commText\":\"B0$ (Playing XI): Abhishek Sharma, Travis Head, Ishan Kishan(w/c), Heinrich Klaasen, Aniket Verma, Nitish Kumar Reddy, Salil Arora, Harsh Dubey, Harshal Patel, Jaydev Unadkat, Eshan Malinga\",\"timestamp\":1774704882492,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Sunrisers Hyderabad\"]}}},{\"commText\":\"B0$ Feeling good because it’s our first game. We would have bowled first after winning the toss, but it looks like a fresh wicket. At the end of the day, it doesn’t matter whether you’re batting first or bowling first, you just need to back your instincts. That will be the plan. Just trying to keep things simple. You don’t have to start doing something new just because it’s the IPL. The plans are clear with all the players, and we’ll just look to execute them well. Pat (Cummins) is one of the best bowlers in the team and in the IPL as well. Missing him makes a big difference. But I think everyone is in good touch, and it’s just about executing our plans. If we do that, we’ll be on the winning side. I think B1$ is one to watch. He’s been in very good touch, and I just want him to keep things simple, watch the ball and play his game.\",\"timestamp\":1774704817283,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\",\"B1$\"],\"formatValue\":[\"Ishan Kishan:\",\"Salil (Arora)\"]}}},{\"commText\":\"B0$ We'll bowl first. Of course, there are a lot of positives from last year, but as we go into this season, we are not defending, we’ll try to be champions again in 2026. I think there are a lot of good players in the side and we have proper backups for every position. There’s a good support system and medical team as well. So yeah, everyone is fit and looking forward to this game. Thank you so much for supporting us over the years. We’ll try our best to put a second star on our jersey. There are two new faces - B1$ and B2$ who are going to play their first match.\",\"timestamp\":1774704723697,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\",\"B1$\",\"B2$\"],\"formatValue\":[\"Rajat Patidar:\",\"Jacob Duffy\",\"Abhinandan Singh\"]}}},{\"commText\":\"B0$\",\"timestamp\":1774704683888,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Royal Challengers Bengaluru have won the toss and have opted to field\"]}}},{\"commText\":\"At 27y \u0026 253d, Ishan Kishan will become Sunrisers Hyderabad’s second-youngest skipper, behind Kane Williamson (27y, 244d) in 2018.\",\"timestamp\":1774704120465,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"\\\"15 mins to toss and Andy and Mo Bobat get the entire RCB squad and support staff into a giant huddle,\\\" says Kaushik. Can see Andy Flower deliver an animated talk. I think we are nearly full.. Would say 90% are in the stadium, some are in the hospitality lounges , can spot them behind the glass panels.\",\"timestamp\":1774704089832,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"B0$ This will be the 7th time RCB feature in a season opener, while SRH do so for only the second time-their first being in 2017, also against the same opponent.\",\"timestamp\":1774704089822,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"STAT:\"]}}},{\"commText\":\"B0$ No pressure (when reminded of his hundred at this venue in 2024). It’s nice to have good memories. Great to be starting the season here, it comes with expectations and excitement. Good to be back. It feels like that sometimes, but it depends on the wicket, conditions, and form. It’s a new season - take it one ball at a time, settle in, and see where it goes. Not really. But it’s great to be back with him. He’s been winning World Cups and playing brilliantly. He’s come a long way, and I’m looking forward to opening with him again. A bit of both. Ishan is a great leader and knows the team’s style. Dan and Pat have been around too, so it feels like a settled squad. Everyone’s excited and in form - ready to go. (300 on the cards this season?) Let's wait and see.\",\"timestamp\":1774702556702,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Travis Head:\"]}}},{\"commText\":\"Rain is predicted tonight, but with Chinnaswamy’s top-notch drainage, a full T20 match should still be on the cards. Here’s hoping the weather holds up and the only shower we witness is one of sixes.\",\"timestamp\":1774702556692,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"B0$ Duffy and Romario have marked their run-ups for RCB.\",\"timestamp\":1774702556682,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Warmup updates -\"]}}},{\"commText\":\"\\\"RCB players are wearing training kits with Jersey No.11 as tribute to the 11 people that lost their lives at the stampede last year,\\\" informs B0$\",\"timestamp\":1774702556672,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Kaushik.\"]}}},{\"commText\":\"Last year’s tragic stampede outside the stadium, which claimed 11 lives, remains a sobering reminder of the responsibility that comes with such grand events. And as cricket returns to this venue, it does so with respect, remembrance and a renewed commitment to safety. Cricket, at its heart, is a game of resilience. As we honour those we lost, the spirit of the sport endures, that the show must go on.\",\"timestamp\":1774702556662,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"\\\"Hello and happy IPL 2026 to you,\\\" - greets our correspondent B0$, from the Chinnaswamy. \\\"The RCB team bus has just made its way to the MCS where a bunch of 'Home of the Champions' banners welcomed them,\\\" he adds. SRH meanwhile have already begun warum ups. David Payne the left-arm quick is doing a lot of visualisation, and now marking his run-up.\",\"timestamp\":1774702348409,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Kaushik Rangarajan\"]}}},{\"commText\":\"B0$ 65 meters on one side, 64 on the other. 73 meters down the ground. Weather conditions are good. Set for a lovely, lovely, lovely batting display. The surface has got a beautiful covering of grass. Yes there are a few of bare patches. Do I think they will make too much of an impact - I'm not so sure. You see the size of these players, the muscles of these players, the sizes of their bats - these boundaries aren't big enough. You walk out to bat on a wicket like this, you stand, take guard and you say to yourself - runs. Having said that, win the toss, chase.\",\"timestamp\":1774701731618,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Pitch and conditions | Kevin Pietersen and Danny Morrison:\"]}}},{\"commText\":\"There are a few fresh faces in the Royal Challengers Bengaluru squad, which adds an extra layer of intrigue to this match. Venkatesh Iyer, Mangesh Yadav and Jacob Dubby are all part of the RCB setup this season, so it will be interesting to see how they fit into the playing XI. How quickly they adapt to their roles and gel with the squad could play an important role in shaping RCB’s 2026 campaign. For the Sunrisers, Ishan Kishan is set to lead the side in the absence of Pat Cummins at the start of the season; a significant responsibility that the dynamic wicketkeeper-batter will be eager to embrace. Known for his aggressive approach at the top, Kishan’s leadership and intent could set the tone for SRH.\",\"timestamp\":1774701721962,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"When you stack up the batting line-ups, Sunrisers Hyderabad appear to have a slight edge, boasting a formidable unit featuring Abhishek Sharma, Travis Head, Ishan Kishan, Liam Livingstone and Heinrich Klaasen. That said, you can never count out the defending champions. With the likes of Virat Kohli, Phil Salt, Rajat Patidar, Tim David and Jitesh Sharma, Royal Challengers Bengaluru possess a strong and capable batting line-up of their own. In a game dominated by batting strength on both sides, the spotlight inevitably shifts to the bowlers. Whichever bowling unit handles the pressure better and executes its plans effectively is likely to decide the outcome of this high-voltage opener.\",\"timestamp\":1774701431433,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"Two heavyweights go head-to-head at the Chinnaswamy in the first clash of the season. The defending champions, Royal Challengers Bengaluru, take on a formidable Sunrisers Hyderabad side. With one of the most explosive batting line-ups in the tournament, the Sunrisers Hyderabad promise a thrilling contest, so this game has all the ingredients of a blockbuster.\",\"timestamp\":1774701267780,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{}},{\"commText\":\"B0$ As the final ball was bowled and history was made, the city transformed into a sea of red and gold. From Indiranagar to Whitefield, MG Road to Koramangala, fans poured out onto the streets well past midnight, turning the entire city into one giant celebration ground. It was pure chaos, joy and emotion. It took 18 long years for Royal Challengers Bangalore to finally lift their maiden IPL trophy and what a moment it turned out to be! The wait, filled with heartbreaks and near-misses across the previous seasons, made the triumph even more special. And now, here we are again. The IPL 2025 final was played on June 3 and after a gap of over nine months, the excitement returns. It’s time for the 19th edition of the Indian Premier League. A very warm welcome to all of you!\",\"timestamp\":1774700984195,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"18:00 Local Time, 12:30 GMT, 18:00 IST:\"]}}},{\"commText\":\"B0$\",\"timestamp\":1774610448200,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Squads:\"]}}},{\"commText\":\"B0$ Squad: Virat Kohli, Philip Salt, Devdutt Padikkal, Rajat Patidar(c), Tim David, Jitesh Sharma(w), Krunal Pandya, Romario Shepherd, Bhuvneshwar Kumar, Suyash Sharma, Jacob Duffy, Josh Hazlewood, Rasikh Salam Dar, Venkatesh Iyer, Mangesh Yadav, Vihaan Malhotra, Vicky Ostwal, Abhinandan Singh, Jacob Bethell, Jordan Cox, Swapnil Singh, Kanishk Chouhan, Satvik Deswal\",\"timestamp\":1774610446045,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Royal Challengers Bengaluru\"]}}},{\"commText\":\"B0$ Squad: Abhishek Sharma, Travis Head, Ishan Kishan(w/c), Liam Livingstone, Heinrich Klaasen, Aniket Verma, Nitish Kumar Reddy, Harshal Patel, Jaydev Unadkat, Harsh Dubey, Eshan Malinga, Shivam Mavi, Smaran Ravichandran, Zeeshan Ansari, Salil Arora, Kamindu Mendis, Brydon Carse, David Payne, Praful Hinge, Sakib Hussain, Krains Fuletra, Amit Kumar, Onkar Tarmale, Shivang Kumar\",\"timestamp\":1774610434864,\"ballNbr\":0,\"event\":\"NONE\",\"batTeamName\":\"\",\"commentaryFormats\":{\"bold\":{\"formatId\":[\"B0$\"],\"formatValue\":[\"Sunrisers Hyderabad\"]}}}]}],\"commentarySnippetList\":{\"0\":[{\"commId\":142729,\"matchId\":149618,\"inningsId\":0,\"infraType\":\"Comment - Forecast\",\"headline\":\"Action-packed start coming up\",\"content\":\"One of the most explosive top-orders on a pitch that should be good for batting. Recipe for runs. Expect SRH to score over 60 in the powerplay. There will be movement too, so they will lose one wicket at least.\",\"timestamp\":1774705149210,\"parsedContent\":[],\"isLive\":false,\"tags\":[]},{\"commId\":142728,\"matchId\":149618,\"inningsId\":0,\"infraType\":\"Content Promotion - Video\",\"headline\":\"Cricbuz